<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Digital Detox Icon — Custom Design
        Concept: A white leaf with a phone-shaped transparent cutout.
        The green background shows through the phone hole, symbolising
        nature reclaiming time from digital screens.

        Safe zone: 72 × 72 dp centred at (54, 54)
        Leaf  : teardrop from (28,18) → (80,18) → (54,86)
        Phone : rounded-rect hole (46,40) → (62,72)
    -->

    <!-- Leaf silhouette with phone-shape punched through (even-odd fill) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M54,86
            C72,72 80,56 80,44
            C80,30 68,18 54,18
            C40,18 28,30 28,44
            C28,56 36,72 54,86 Z
            M46,43
            Q46,40 49,40
            L59,40
            Q62,40 62,43
            L62,69
            Q62,72 59,72
            L49,72
            Q46,72 46,69 Z" />

    <!-- Centre vein above the phone hole -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#60FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M54,22 L54,38" />

    <!-- Centre vein below the phone hole -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#60FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M54,74 L54,82" />

    <!-- Small speaker bar inside the phone hole (white on green bg) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#BDFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M50,44.5 L58,44.5" />

    <!-- Home-button indicator inside the phone hole -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#BDFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M51,68 L57,68" />

</vector>